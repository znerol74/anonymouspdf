---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl } from '../i18n/utils';
import { LOCALE_META, ogLocale, isRtl, defaultLang, type Lang } from '../i18n/site';
import type { AltLink } from '../i18n/routes';

interface Props {
  title: string;
  description: string;
  alternates?: AltLink[];
  ogImage?: string;
  jsonLd?: unknown;
  noindex?: boolean;
  lang?: Lang;
}

const {
  title,
  description,
  alternates = [],
  ogImage = '/og/default.png',
  jsonLd,
  noindex = false,
  lang: langProp,
} = Astro.props;

const lang = langProp ?? getLangFromUrl(Astro.url);
const site = Astro.site ?? new URL('https://anonymouspdf.com');
const canonical = new URL(Astro.url.pathname, site).href;
const ogImageUrl = new URL(ogImage, site).href;
const xDefault = alternates.find((a) => a.locale === defaultLang) ?? alternates[0];
---

<!doctype html>
<html lang={LOCALE_META[lang].htmlLang} dir={isRtl(lang) ? 'rtl' : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-RP56CCTV9B"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-RP56CCTV9B');
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {
      alternates.map((a) => (
        <link rel="alternate" hreflang={a.locale} href={new URL(a.path, site).href} />
      ))
    }
    {xDefault && <link rel="alternate" hreflang="x-default" href={new URL(xDefault.path, site).href} />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AnonymousPDF" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale(lang)} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/png" href="/favicon.png" />

    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body class="flex min-h-screen flex-col bg-white text-slate-900 antialiased">
    <Header alternates={alternates} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
