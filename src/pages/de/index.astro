---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeContent from '../../components/HomeContent.astro';
import { alternatesFor } from '../../i18n/routes';

const title = 'AnonymousPDF — PDF schwärzen & anonymisieren, kostenlos im Browser';
const description =
  'Kostenloses Online-Tool zum Schwärzen und Anonymisieren von PDF-Dateien. Erkennt und entfernt automatisch E-Mails, Telefonnummern, IBANs, Aktenzeichen und Namen — 100% im Browser. Dateien verlassen niemals Ihr Gerät.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'AnonymousPDF',
  url: 'https://anonymouspdf.com/de/',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any (web browser)',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
  description,
};
---

<BaseLayout title={title} description={description} alternates={alternatesFor('home')} jsonLd={jsonLd}>
  <HomeContent />
</BaseLayout>
