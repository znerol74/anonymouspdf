---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeContent from '../../components/HomeContent.astro';
import { alternatesFor } from '../../i18n/routes';

const title = 'AnonymousPDF — Redact & Anonymize PDF Online, Free & In-Browser';
const description =
  'Free online tool to redact and anonymize PDF files. Automatically detects and removes emails, phone numbers, IBANs, IDs and names — 100% in your browser. Files never leave your device.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'AnonymousPDF',
  url: 'https://anonymouspdf.com/en/',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any (web browser)',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description,
};
---

<BaseLayout title={title} description={description} alternates={alternatesFor('home')} jsonLd={jsonLd}>
  <HomeContent />
</BaseLayout>
