---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Landing from '../../components/Landing.astro';
import { landing, faqLd } from '../../content/landing';
import { alternatesFor } from '../../i18n/routes';

const copy = landing['data-masking'].en!;
---

<BaseLayout
  title={copy.seoTitle}
  description={copy.seoDescription}
  alternates={alternatesFor('data-masking')}
  jsonLd={faqLd(copy.faq)}
>
  <Landing copy={copy} lang="en" />
</BaseLayout>
