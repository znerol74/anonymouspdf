---
import { getLangFromUrl } from '../i18n/utils';
import { LIVE_LOCALES, LOCALE_META, type Lang } from '../i18n/site';
import { pathFor, type AltLink } from '../i18n/routes';

interface Props {
  alternates?: AltLink[];
}

const { alternates = [] } = Astro.props;
const current = getLangFromUrl(Astro.url);

function urlFor(lang: Lang): string {
  const alt = alternates.find((a) => a.locale === lang);
  return alt ? alt.path : (pathFor('home', lang) ?? `/${lang}/`);
}
---

<details data-lang-switcher class="group relative">
  <summary class="flex cursor-pointer list-none items-center gap-1.5 rounded-lg border border-slate-200 px-3 py-1.5 text-sm font-medium text-slate-700 marker:content-none hover:bg-slate-50">
    <svg class="h-4 w-4 text-slate-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="12" cy="12" r="9" />
      <path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18" />
    </svg>
    <span>{LOCALE_META[current].label}</span>
    <svg class="h-4 w-4 text-slate-400 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="m6 9 6 6 6-6" />
    </svg>
  </summary>
  <ul class="absolute end-0 z-20 mt-2 max-h-80 w-48 overflow-auto rounded-xl border border-slate-200 bg-white p-1 shadow-lg">
    {
      LIVE_LOCALES.map((lang) => (
        <li>
          <a
            href={urlFor(lang)}
            hreflang={lang}
            data-track="lang_switch"
            data-track-target={lang}
            class:list={[
              'block rounded-lg px-3 py-2 text-sm',
              lang === current ? 'bg-slate-900 font-medium text-white' : 'text-slate-700 hover:bg-slate-50',
            ]}
          >
            {LOCALE_META[lang].label}
          </a>
        </li>
      ))
    }
  </ul>
</details>

<script is:inline>
  document.addEventListener('click', (e) => {
    document.querySelectorAll('details[data-lang-switcher][open]').forEach((d) => {
      if (!d.contains(e.target)) d.removeAttribute('open');
    });
  });
</script>
