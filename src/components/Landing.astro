---
import RedactionTool from './RedactionTool.tsx';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import type { LandingCopy } from '../content/landing';

interface Props {
  copy: LandingCopy;
  lang: Lang;
}

const { copy, lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="bg-gradient-to-b from-brand-50 to-white">
  <div class="mx-auto max-w-6xl px-4 py-16 text-center sm:py-20">
    <h1 class="mx-auto max-w-3xl text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
      {copy.h1}
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-slate-600">{copy.sub}</p>
    <RedactionTool client:load lang={lang} />
  </div>
</section>

<section class="mx-auto max-w-3xl px-4 py-16">
  <div class="space-y-4 text-base leading-relaxed text-slate-700">
    {copy.intro.map((p) => <p>{p}</p>)}
  </div>
</section>

<section class="bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-8 sm:grid-cols-3">
      {
        copy.steps.map((s) => (
          <div>
            <h3 class="font-semibold text-slate-900">{s.title}</h3>
            <p class="mt-2 text-sm text-slate-600">{s.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<section class="mx-auto max-w-3xl px-4 py-16">
  <h2 class="text-2xl font-bold text-slate-900">{copy.faqHeading}</h2>
  <div class="mt-6 divide-y divide-slate-200 border-t border-slate-200">
    {
      copy.faq.map((f) => (
        <details class="group py-4">
          <summary class="cursor-pointer list-none font-medium text-slate-900 marker:content-none">
            {f.q}
          </summary>
          <p class="mt-2 text-sm text-slate-600">{f.a}</p>
        </details>
      ))
    }
  </div>
</section>

<section class="bg-slate-50">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-16 sm:grid-cols-3">
    <div class="rounded-xl border border-slate-200 bg-white p-6">
      <h3 class="font-semibold text-slate-900">{t('trust.local.title')}</h3>
      <p class="mt-2 text-sm text-slate-600">{t('trust.local.body')}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-6">
      <h3 class="font-semibold text-slate-900">{t('trust.free.title')}</h3>
      <p class="mt-2 text-sm text-slate-600">{t('trust.free.body')}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-6">
      <h3 class="font-semibold text-slate-900">{t('trust.true.title')}</h3>
      <p class="mt-2 text-sm text-slate-600">{t('trust.true.body')}</p>
    </div>
  </div>
</section>
