---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { AltLink } from '../i18n/routes';

interface Props {
  alternates?: AltLink[];
}

const { alternates = [] } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const home = `/${lang}/`;
const redact = lang === 'de' ? '/de/pdf-schwaerzen/' : '/en/redact-pdf/';
const anonymize = lang === 'de' ? '/de/pdf-anonymisieren/' : '/en/anonymize-pdf/';
---

<header class="border-b border-slate-200 bg-white">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <a href={home} class="flex items-center gap-2 text-lg font-bold text-slate-900">
      <img src="/logo.png" alt="AnonymousPDF" width="28" height="28" class="h-7 w-7" />
      <span>{t('site.name')}</span>
    </a>
    <div class="flex items-center gap-5 text-sm font-medium text-slate-600">
      <a href={redact} class="hidden hover:text-brand-700 sm:inline">{t('nav.redact')}</a>
      <a href={anonymize} class="hidden hover:text-brand-700 sm:inline">{t('nav.anonymize')}</a>
      <LanguageSwitcher alternates={alternates} />
    </div>
  </nav>
</header>
